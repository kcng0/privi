# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (keep shared settings, ignore user/workspace state)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Flutter/Dart/Pub
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
# NOTE: pubspec.lock IS committed (this is an app, not a package) for reproducible builds.

# Generated code (regenerated by build_runner)
*.g.dart
*.freezed.dart
*.config.dart
*.mocks.dart

# FVM (Flutter Version Management) — keep .fvmrc, ignore the local SDK symlink/cache
.fvm/flutter_sdk
.fvm/versions

# Symbolication / obfuscation
app.*.symbols
app.*.map.json

# Android
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks
*.keystore

# Local env / secrets
.env
*.local
