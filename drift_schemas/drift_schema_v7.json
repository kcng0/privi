  "fixed_sql": [
    {
      "name": "media_items",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"media_items\" (\"id\" TEXT NOT NULL, \"private_path\" TEXT NOT NULL, \"original_path\" TEXT NULL, \"original_name\" TEXT NOT NULL, \"mime_type\" TEXT NOT NULL, \"is_video\" INTEGER NOT NULL CHECK (\"is_video\" IN (0, 1)), \"width\" INTEGER NULL, \"height\" INTEGER NULL, \"duration_ms\" INTEGER NULL, \"rating\" INTEGER NOT NULL DEFAULT 0, \"date_added\" INTEGER NOT NULL, \"date_taken\" INTEGER NULL, \"size_bytes\" INTEGER NOT NULL, \"thumbnail_path\" TEXT NULL, \"deleted_at\" INTEGER NULL, \"source_platform_id\" TEXT NULL, \"source_removal_pending\" INTEGER NOT NULL DEFAULT 0 CHECK (\"source_removal_pending\" IN (0, 1)), \"content_digest\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "albums",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"albums\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"is_system\" INTEGER NOT NULL CHECK (\"is_system\" IN (0, 1)), \"cover_media_id\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"system_kind\" TEXT NULL, \"pinned_at\" INTEGER NULL, \"rating\" INTEGER NOT NULL DEFAULT 0, \"sort_index\" INTEGER NULL, \"group_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "album_media",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"album_media\" (\"album_id\" TEXT NOT NULL REFERENCES albums (id), \"media_id\" TEXT NOT NULL REFERENCES media_items (id), \"added_at\" INTEGER NOT NULL, PRIMARY KEY (\"album_id\", \"media_id\"));"
        }
      ]
    },
    {
      "name": "album_groups",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"album_groups\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL, \"sort_index\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    }
  ]
